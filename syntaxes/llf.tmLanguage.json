{
    "scopeName": "source.llf",
    "patterns": [
        { "include": "#comment" },
        { "include": "#multiline-continuation" },
        { "include": "#key-value" }
    ],
    "repository": {
        "comment": {
            "patterns": [
                {
                    "match": "^\\s*(#)(.*)$",
                    "captures": {
                        "1": { "name": "punctuation.definition.comment.llf" },
                        "2": { "name": "comment.line.llf" }
                    }
                }
            ]
        },
        "multiline-continuation": {
            "patterns": [
                {
                    "match": "^(  )(.*)$",
                    "captures": {
                        "1": { "name": "punctuation.whitespace.multiline.llf" },
                        "2": { "name": "string.multiline.continuation.llf" }
                    }
                }
            ]
        },
        "key-value": {
            "patterns": [
                {
                    "match": "^(.*?)(\\s*)(: )(>-\\s*)(.*)$",
                    "captures": {
                        "1": { "name": "entity.name.label.key.llf" },
                        "2": { "name": "punctuation.whitespace.llf" },
                        "3": { "name": "punctuation.separator.key-value.llf" },
                        "4": { "name": "keyword.operator.multiline.llf" },
                        "5": { "name": "string.value.llf" }
                    }
                },
                {
                    "match": "^(.*?)(\\s*)(: )(.*)$",
                    "captures": {
                        "1": { "name": "entity.name.label.key.llf" },
                        "2": { "name": "punctuation.whitespace.llf" },
                        "3": { "name": "punctuation.separator.key-value.llf" },
                        "4": { "name": "string.value.llf" }
                    }
                }
            ]
        }
    }
}